# Base image for in-cluster test runner.
# Rebuilt when frontend dependencies change (see test-runner-base.yml).
# Bakes in Playwright browsers + node_modules for fast test-file-only rebuilds.

FROM mcr.microsoft.com/playwright:v1.57.0-noble

WORKDIR /app

# Install dependencies (cached in base image)
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

# Browsers are pre-installed in the Playwright base image
