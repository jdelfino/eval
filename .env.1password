# 1Password secret references for eval
#
# Format: VARIABLE_NAME=op://${OP_VAULT}/item-name/field-name
#
# This file is processed by setup-secrets.sh on container start.
# envsubst expands ${OP_VAULT}, then op inject resolves the references.
#
# Example:
# API_KEY=op://${OP_VAULT}/my-api/key
# DATABASE_URL=op://${OP_VAULT}/database/connection-string
