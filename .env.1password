# 1Password secret references for eval
#
# Format: VARIABLE_NAME=[1password-secret-reference]
#
# This file is processed by setup-secrets.sh on container start.
# envsubst expands ${OP_VAULT}, then op inject resolves the references.
# NOTE: Do not put secret references in comments — op inject tries to resolve them all.
#
# GH_TOKEN is handled separately in setup.sh (file-based, like OP_SERVICE_ACCOUNT_TOKEN).
