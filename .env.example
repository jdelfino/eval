# Environment variables for eval
# Copy to .env.local and fill in values
#
# For 1Password integration, add references to .env.1password instead

# =============================================================================
# Local Development Configuration
# =============================================================================
# These values are used when running locally with Docker Compose.
# In staging/prod, these values come from Kubernetes ConfigMaps and Secrets
# created by Terraform.

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
AWS_REGION=us-west-2

# -----------------------------------------------------------------------------
# Cognito Configuration (Local: cognito-local)
# -----------------------------------------------------------------------------
# Local development uses cognito-local (jagregory/cognito-local)
COGNITO_ENDPOINT=http://localhost:9229
COGNITO_USER_POOL_ID=local_pool
COGNITO_CLIENT_ID=local_client
COGNITO_CLIENT_SECRET=local_secret
COGNITO_DOMAIN=http://localhost:9229

# -----------------------------------------------------------------------------
# Database Configuration (Local: Docker Postgres)
# -----------------------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=eval
DATABASE_USER=eval
DATABASE_PASSWORD=eval_local_password
DATABASE_URL=postgresql://eval:eval_local_password@localhost:5432/eval

# -----------------------------------------------------------------------------
# Redis Configuration (Local: Docker Redis)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Server port for the Go API
PORT=8080

# Log level (debug, info, warn, error)
LOG_LEVEL=debug

# Environment identifier
ENVIRONMENT=local
