# Environment variables for eval
# Copy to .env.local and fill in values
#
# For 1Password integration, add references to .env.1password instead

# =============================================================================
# Local Development Configuration
# =============================================================================
# These values are used when running locally with Docker Compose.
# In prod, these values come from Kubernetes ConfigMaps and Secrets
# created by Terraform.

# -----------------------------------------------------------------------------
# GCP Configuration
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=eval-prod-485520
GCP_REGION=us-east1

# -----------------------------------------------------------------------------
# Identity Platform Configuration (Local: mock auth or Firebase emulator)
# -----------------------------------------------------------------------------
# Local development can use Firebase Auth emulator or mock middleware
IDENTITY_PLATFORM_API_KEY=local_api_key
IDENTITY_PLATFORM_AUTH_DOMAIN=localhost
OAUTH_CLIENT_ID=local_client
OAUTH_CLIENT_SECRET=local_secret

# -----------------------------------------------------------------------------
# Database Configuration (Local: Docker Postgres)
# -----------------------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=eval
DATABASE_USER=eval
DATABASE_PASSWORD=eval_local_password
DATABASE_URL=postgresql://eval:eval_local_password@localhost:5432/eval

# -----------------------------------------------------------------------------
# Redis Configuration (Local: Docker Redis)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Server port for the Go API
PORT=8080

# Log level (debug, info, warn, error)
LOG_LEVEL=debug

# Environment identifier
ENVIRONMENT=local
