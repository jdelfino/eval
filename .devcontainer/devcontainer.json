{
  "name": "eval",
  "image": "mcr.microsoft.com/devcontainers/base:trixie",

  "workspaceMount": "source=eval-workspace,target=/workspaces/eval,type=volume",
  "workspaceFolder": "/workspaces/eval",

  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached"
  ],

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": { "moby": false },
    "ghcr.io/devcontainers/features/node:1": { "version": "22", "installYarnUsingApt": false },
    "ghcr.io/devcontainers/features/go:1": { "version": "1.22" },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": { "helm": "none", "minikube": "none" },
    "ghcr.io/devcontainers/features/terraform:1": {}
  },
  "initializeCommand": "./.devcontainer/init-1password.sh",
  "postCreateCommand": "ls -la /workspaces/eval/.devcontainer/ && echo CWD=$(pwd) && ls -la .devcontainer/ || echo 'relative path failed'",

  "remoteEnv": {
    "BD_SOCKET": "/tmp/beads.sock"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "planet57.vscode-beads"
      ]
    }
  }
}
