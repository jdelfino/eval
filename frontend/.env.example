# Go Backend API URL
# The frontend calls the Go backend directly (no BFF/proxy)
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Firebase Configuration
# Get these from Firebase Console > Project Settings > General > Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Centrifugo WebSocket URL
# Used for real-time session updates
NEXT_PUBLIC_CENTRIFUGO_URL=ws://localhost:8000/connection/websocket

# Firebase Auth Emulator (E2E testing only)
# Set to connect the Firebase Auth SDK to the local emulator instead of production.
# Only needed when running E2E tests with USE_FIREBASE_EMULATOR=1 (make test-e2e-auth).
# NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=http://localhost:9099
