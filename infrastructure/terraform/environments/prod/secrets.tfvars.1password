# 1Password secret references for Terraform
#
# Format: variable = "op://${OP_VAULT}/item-name/field-name"
#
# This file is processed by setup-secrets.sh on container start.
# envsubst expands ${OP_VAULT}, then op inject resolves the references.

oauth_client_id     = "op://${OP_VAULT}/gcp-oauth/client-id"
oauth_client_secret = "op://${OP_VAULT}/gcp-oauth/client-secret"
